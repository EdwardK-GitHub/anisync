# Local PostgreSQL running through docker-compose.yml
DATABASE_URL=postgresql+psycopg://anisync:anisync@localhost:54329/anisync

# Change this in real deployment.
SESSION_SECRET=replace-this-with-a-long-random-secret

# Local frontend origin.
FRONTEND_ORIGIN=http://localhost:5173

# Local cookies work over HTTP.
COOKIE_SECURE=false
COOKIE_SAME_SITE=lax

# Local media folder served by FastAPI.
MEDIA_ROOT=../media
MEDIA_BASE_URL=/media

# Embedding model required by the design document.
EMBEDDING_MODEL_NAME=sentence-transformers/all-MiniLM-L6-v2

# Optional deployment-only Supabase media sync values.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_STORAGE_BUCKET=anisync-media
